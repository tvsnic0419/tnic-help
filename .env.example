# Canonical URL — set in Vercel Production to https://tnic.help
NEXT_PUBLIC_SITE_URL=https://tnic.help

# Protocol Brief — Resend native delivery (preferred when configured)
RESEND_API_KEY=
RESEND_FROM_EMAIL=brief@tnic.help
RESEND_AUDIENCE_ID=
BRIEF_FALLBACK_EMAIL=

# Brief unsubscribe HMAC — defaults to CRON_SECRET when unset
BRIEF_UNSUBSCRIBE_SECRET=

# Weekly cron — required in production; Vercel Cron sends Bearer automatically
CRON_SECRET=

# Protocol Brief — fallback webhook when Resend audience is not set
BRIEF_SUBSCRIBE_WEBHOOK_URL=

# Lab partner — required in production for POST /api/labs/partner/webhook
LAB_WEBHOOK_SECRET=

# Lab partner — OAuth client id for live partner redirects
LAB_OAUTH_CLIENT_ID=tnic

# Longevity Direct live OAuth (all required to enable live partner)
LONGEVITY_DIRECT_AUTHORIZE_URL=
LONGEVITY_DIRECT_TOKEN_URL=
LONGEVITY_DIRECT_ORDER_URL=
LONGEVITY_DIRECT_STATUS_URL=
LONGEVITY_DIRECT_CLIENT_ID=
LONGEVITY_DIRECT_CLIENT_SECRET=